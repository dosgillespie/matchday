# Copy this file to .env for local development.
# In production these are set as GitHub Actions secrets/variables instead.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Optional: namespace for your team's data (lets several teams share one database)
VITE_TEAM_ID=default
